# URL pública del sitio (Open Graph, metadataBase, robots.txt)
# Debe ser el dominio de producción SIN protección de despliegue de Vercel.
NEXT_PUBLIC_SITE_URL=https://ficatostadores.vercel.app
# Firebase (cliente — públicas)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# OAuth 2.0 Web client ID (Google Cloud → APIs y servicios → Credenciales).
# Suele coincidir con el cliente web auto-creado por Firebase en el mismo proyecto.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=730909202093-qhc5g15djdir1ae1jua7jlnklu91qh8n.apps.googleusercontent.com

# Firebase Admin (servidor — Firestore: productos, catálogo, cotizaciones)
# Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada
# Opción A: ruta al JSON descargado (recomendado en local; no subir a Git)
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Opción B: JSON en una línea (texto plano o base64) — usar en Vercel
FIREBASE_SERVICE_ACCOUNT_JSON=

# Rate limiting distribuido (recomendado en Vercel / producción)
# Crear base gratis en https://upstash.com y pegar credenciales REST
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App Electron de cotizaciones (heartbeat → /api/electron/heartbeat)
COTIZACIONES_APP_SECRET=
# COTIZACIONES_APP_HEARTBEAT_TIMEOUT_SEC=90

# Orígenes extra para `next dev` en red local (opcional, separados por coma).
# Next.js también detecta IPs LAN automáticamente; use esto solo si hace falta.
# EXTRA_DEV_ORIGINS=192.168.3.107
#
# Login con Google en red local: en Firebase Console → Authentication → Configuración
# → Dominios autorizados, agregue localhost y su IP (ej. 192.168.3.107).
#
# Si en la consola aparece init.json 404 en *.firebaseapp.com, desplegá hosting una vez:
#   npm i -g firebase-tools && firebase login && firebase deploy --only hosting

# Opción A (recomendada): conectar Blob Storage al proyecto → BLOB_STORE_ID (OIDC automático)
# Opción B (legacy): BLOB_READ_WRITE_TOKEN=
# Blob se usa solo para imágenes de productos (no para el catálogo JSON).
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
